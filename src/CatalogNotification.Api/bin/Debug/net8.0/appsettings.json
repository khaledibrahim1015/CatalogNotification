{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=catalog_db;Username=khaled;Password=kh123;Pooling=true"
  },
  

  "NATS": {
    "Urls": [
      "nats://nats-1:4222",
